                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"

                    android:text="Brand Name" />

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">
                    <EditText android:text=""
                        android:id="@+id/brandname"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_width="fill_parent"
                        android:inputType="none"
                        android:textIsSelectable="true"
                        android:focusable="false">
                    </EditText>
                    <Button android:text="Select"
                        android:id="@+id/Button_brandname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                    </Button>
                </LinearLayout>


                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"

                    android:text="Model Name" />

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">
                    <EditText android:text=""
                        android:id="@+id/modelname"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_width="fill_parent"
                        android:inputType="none"
                        android:textIsSelectable="true"
                        android:focusable="false">
                    </EditText>
                    <Button android:text="Select"
                        android:id="@+id/Button_modelname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                    </Button>

                </LinearLayout>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"

                    android:text="Quantity" />

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">

                    <EditText
                        android:id="@+id/quantity"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_width="fill_parent"
                        android:inputType="number"
                        android:gravity="right"
                        android:text="1">
                    </EditText>
                </LinearLayout>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"

                    android:text="Unit Rate" />

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">

                    <EditText
                        android:id="@+id/unitprice_include_tax"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_width="fill_parent"
                        android:inputType="numberDecimal"
                        android:gravity="right">
                    </EditText>


                </LinearLayout>
            </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/login_error"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="10dip"
            android:textColor="#e30000"
            android:textSize="15sp"
            android:textStyle="bold" />
        <!-- Submit Button Outside Cards -->
        <Button
            android:id="@+id/btnCreateFinance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:text="Create Customer / Order / Finance"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:layout_margin="16dp"/>
    </LinearLayout>
</ScrollView>
