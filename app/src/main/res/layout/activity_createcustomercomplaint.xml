<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:label="@string/app_name">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dip" >

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dip"
            android:text="Mobile No"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/mobileno"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:textSize="15sp"
            android:inputType="number"
            android:text=""
            android:maxLines="1"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Name" />

        <EditText
            android:id="@+id/name"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:textSize="15sp"
            android:text=""
            android:maxLines="1"
            android:inputType="textCapCharacters"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Address" />

        <EditText
            android:id="@+id/address1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="1"/>

        <EditText
            android:id="@+id/address2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="1"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Pincode" />

        <EditText
            android:id="@+id/pincode"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="1"
            android:inputType="number"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Email" />

        <EditText
            android:id="@+id/email"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="1"/>



        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Brand Name" />

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <EditText android:text=""
                android:id="@+id/brandname"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_width="fill_parent"
                android:inputType="textCapCharacters">
            </EditText>
            <Button android:text="Add"
                android:id="@+id/Button_brandname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
            </Button>
        </LinearLayout>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Top Category" />

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <EditText android:text=""
                android:id="@+id/topcategory"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_width="fill_parent"
                android:inputType="textCapCharacters">
            </EditText>
            <Button android:text="Add"
                android:id="@+id/Button_topcategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="onClick_supplier">
            </Button>

        </LinearLayout>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Salect Customer Product" />

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <EditText
                android:id="@+id/modelname"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_width="fill_parent"
                android:inputType="none"
                android:textIsSelectable="true"
                android:focusable="false">
            </EditText>

            <Button android:text="Product"
                android:id="@+id/add_Customer_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
            </Button>
        </LinearLayout>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Complaint Description" />

        <EditText
            android:id="@+id/inquiredproduct"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:lines="4"
            android:inputType="textMultiLine|textCapCharacters"
            android:gravity="top|left"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Charges" />

        <EditText
            android:id="@+id/priceoffered"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""/>


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Complaint Number" />

        <EditText
            android:id="@+id/referencecode"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""/>



        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

        <Button
            android:id="@+id/submit_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:background="@color/button_bg"
            android:onClick="onClick_submit"
            android:text="Submit"
            android:textColor="#fff" />



        <TextView
            android:id="@+id/login_error"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="10dip"
            android:textColor="#e30000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/list_selector"
                android:orientation="horizontal"
                android:padding="5dip" >

            <TextView
                android:id="@+id/parentcategoryname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:typeface="sans"
                android:textSize="15dip"
                android:textColor="#040404"
                android:textStyle="bold"/>
            <!-- Artist Name -->
            <TextView
                android:id="@+id/invoiceno_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/parentcategoryname"
                android:textColor="#343434"
                android:textSize="15dip"
                android:layout_marginTop="1dip"
                android:text="Invoice No. : "/>

            <!-- Artist Name -->
            <TextView
                android:id="@+id/invoiceno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/parentcategoryname"
                android:textColor="#343434"
                android:textSize="15dip"
                android:layout_marginTop="1dip"
                android:layout_alignParentRight="true"/>


                <TextView
                    android:id="@+id/invoicedt_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/invoiceno_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Invoice Date : "/>

                <!-- Artist Name -->
                <TextView
                    android:id="@+id/invoicedt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/invoiceno"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>



                <TextView
                    android:id="@+id/brandname_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/invoicedt_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Brand : "/>

                <!-- Artist Name -->
                <TextView
                    android:id="@+id/brandname1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/invoicedt"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>

                <TextView
                    android:id="@+id/categoryname_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/brandname_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Sub-Category : "/>

                <!-- Artist Name -->
                <TextView
                    android:id="@+id/categoryname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/brandname1"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>

                <TextView
                    android:id="@+id/serialno_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/categoryname_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Serial No : "/>

                <!-- Artist Name -->
                <TextView
                    android:id="@+id/serialno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/categoryname"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>


                <TextView
                    android:id="@+id/netamt_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/serialno_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Invoice Amount : "/>

                <!-- Artist Name -->
                <TextView
                    android:id="@+id/netamt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/serialno"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>

                <TextView
                    android:id="@+id/manufacturer_warranty_tenure_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/netamt_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Warranty Months : "/>

                <!-- Artist Name -->
                <TextView
                    android:id="@+id/manufacturer_warranty_tenure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/netamt"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>



                <TextView
                    android:id="@+id/warranty_start_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/manufacturer_warranty_tenure_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Warranty From : "/>

                <TextView
                    android:id="@+id/warranty_start_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/manufacturer_warranty_tenure"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>

                <TextView
                    android:id="@+id/warranty_end_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/warranty_start_date_label"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:text="Warranty Upto : "/>

                <TextView
                    android:id="@+id/warranty_end_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/warranty_start_date"
                    android:textColor="#343434"
                    android:textSize="15dip"
                    android:layout_marginTop="1dip"
                    android:layout_alignParentRight="true"/>
            </RelativeLayout>
        </LinearLayout>

    </LinearLayout>


</ScrollView>