<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:label="@string/app_name">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dip" >

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dip"
            android:text="Mobile No"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/mobileno"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:textSize="15sp"
            android:inputType="number"
            android:text=""
            android:maxLines="1"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Name" />

        <EditText
            android:id="@+id/name"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:textSize="15sp"
            android:text=""
            android:maxLines="1"
            android:inputType="textCapCharacters"/>


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Required Product" />

        <EditText
            android:id="@+id/inquiredproduct"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="2"
            android:inputType="textCapCharacters"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Price Offered" />

        <EditText
            android:id="@+id/priceoffered"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:inputType="text|numberDecimal"/>

        <TextView
            android:id="@+id/remarkslbl"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="Note"
            android:text="Note"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/remarks"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:lines="8"
            android:inputType="textMultiLine|textCapCharacters"
            android:gravity="top|left"/>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

        <TextView
            android:id="@+id/pickNextFollowupDatelbl"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="NEXT FOLLOWUP DATE"
            android:text="NEXT FOLLOWUP DATE : "
            android:maxLines="1"/>

        <TextView android:id="@+id/pickNextFollowupDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Followup Date"
            android:textStyle="bold"
            android:textColor="#d40909"
            android:textSize="18dp"
            android:onClick="setPickNextFollowupDate"/>

        <TextView
            android:id="@+id/followuptime"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="NEXT FOLLOWUP TIME"
            android:text="NEXT FOLLOWUP TIME"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/NextFollowupTime"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="Next Followup Time"
            android:textStyle="bold"
            android:textColor="#d40909"
            android:textSize="18dp"
            android:inputType="time"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Address" />

        <EditText
            android:id="@+id/address1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="2"
            android:inputType="textCapCharacters"/>

        <EditText
            android:id="@+id/address2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="2"
            android:inputType="textCapCharacters"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Pincode" />

        <EditText
            android:id="@+id/pincode"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="1"
            android:inputType="number"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Email" />

        <EditText
            android:id="@+id/email"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:hint=""
            android:text=""
            android:maxLines="1"/>

        <TextView
            android:id="@+id/login_error"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="10dip"
            android:textColor="#e30000"
            android:textSize="15sp"
            android:textStyle="bold" />


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Birth Date" />

        <Button android:id="@+id/pickbirthdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Birth Date"
            android:onClick="setBirthDate"
            android:background="@color/white"
            android:textColor="@color/black_overlay"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Anniversory Date" />

        <Button android:id="@+id/pickAniversoryDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aniversory Date"
            android:onClick="setAniversoryDate"
            android:background="@color/white"
            android:textColor="@color/black_overlay"/>

        <Button
            android:id="@+id/submit_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:background="@color/button_bg"
            android:onClick="onClick_submit"
            android:text="Submit"
            android:textColor="#fff" />


        <TextView
            android:id="@+id/folupconversationlbl"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="CONVERSATION"
            android:text="CONVERSATION OR ACTIVITY CLOSED REASON"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/folupconversation"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:lines="8"
            android:inputType="textMultiLine|textCapCharacters"
            android:gravity="top|left"/>


        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:text="Close Followup"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:onClick="WalkInCustomerClose"
            android:layout_margin="3dp"/>


    </LinearLayout>
</ScrollView>