<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <LinearLayout
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_width="fill_parent">
                <TextView
                    android:id="@+id/name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />
                <Button android:text="Edit"
                    android:id="@+id/Update_new_walkin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                </Button>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/mobilelabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/mobilelabel"
                    android:textColor="@android:color/black"/>

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">
                    <TextView
                        android:id="@+id/mobile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@android:color/black"/>

                    <ImageView
                        android:id="@+id/call_mobile"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:src="@drawable/phone"
                        android:layout_gravity="right"/>

                </LinearLayout>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/telephonelabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Alternate Mobile"
                    android:textColor="@android:color/black"/>


            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">
                    <TextView
                        android:id="@+id/telephone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@android:color/black"/>

                    <ImageView
                        android:id="@+id/call_telephone"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:src="@drawable/phone"
                        android:layout_gravity="right"/>

                </LinearLayout>


            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/emaillabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/emailidlabel"
                    android:textColor="@android:color/black"/>


                <TextView
                    android:id="@+id/emailid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_toRightOf="@+id/emaillabel"
                    android:textColor="@android:color/black"/>

            </RelativeLayout>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/outstandinglabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/priceofferredlabel"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/outstanding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_toRightOf="@+id/outstandinglabel"
                    android:textColor="@android:color/black"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/inquiredproductlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/productenquirylabel"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/inquiredproduct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_toRightOf="@+id/inquiredproductlabel"
                    android:textColor="@android:color/black"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/addresslabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Address : "
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_toRightOf="@+id/addresslabel"
                    android:textColor="@android:color/black"/>
            </RelativeLayout>
        </LinearLayout>

            <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">



        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="Call Reference No" />

                <EditText
                    android:id="@+id/activityrefno"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:hint=""
                    android:focusable="false" />


                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:text="Followup Purpose (*)" />

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">

                    <EditText
                        android:id="@+id/purposename"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_width="fill_parent"
                        android:inputType="none"
                        android:textIsSelectable="true"
                        android:focusable="false">
                    </EditText>

                    <Button android:text="Select"
                        android:id="@+id/Button_purposename"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                    </Button>
                </LinearLayout>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:text="Followup Mode (*)" />

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent">

                    <EditText
                        android:id="@+id/modename"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_width="fill_parent"
                        android:inputType="none"
                        android:textIsSelectable="true"
                        android:focusable="false">
                    </EditText>

                    <Button android:text="Select"
                        android:id="@+id/Button_modename"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                    </Button>
                </LinearLayout>


                <TextView
            android:id="@+id/pickNextFollowupDatelbl"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="NEXT FOLLOWUP DATE"
            android:text="NEXT FOLLOWUP DATE : "
            android:maxLines="1"/>

        <TextView android:id="@+id/pickNextFollowupDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Followup Date"
            android:textStyle="bold"
            android:textColor="#d40909"
            android:textSize="18dp"
            android:onClick="setToDate"/>


        <TextView
            android:id="@+id/followuptime"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="NEXT FOLLOWUP TIME"
            android:text="NEXT FOLLOWUP TIME"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/NextFollowupTime"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="Next Followup Time"
            android:textStyle="bold"
            android:textColor="#d40909"
            android:textSize="18dp"
            android:inputType="time"/>


    </LinearLayout>


        <TextView
            android:id="@+id/folupconversationlbl"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="Conversation"
            android:text="Conversation or activity close reason (*)"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/folupconversation"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:lines="4"
            android:inputType="textMultiLine|textCapCharacters"
            android:gravity="top|left"/>


        <Button

            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:onClick="Update_Followup"
            android:text="Update Followup"/>




        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <Button

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="onClick_create_quotation"
                android:text="Create Quotation"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Order"
                android:onClick="onClick_add_product"
                android:layout_weight="1"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Close Followup"
                android:onClick="WalkInCustomerClose"
                android:layout_weight="1"/>
        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>



        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ListView
                android:id="@+id/list_view"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:divider="#b5b5b5"
                android:dividerHeight="1dp"
                android:listSelector="@drawable/list_selector" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textStyle="bold"
                android:id="@+id/header_followuphistory"/>

            <TableLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="0"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tablefollowup_history"
                android:layout_below="@+id/header_followuphistory">
            </TableLayout>

            <Button
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnCapturePicture"
                android:text="Upload Document"
                android:visibility="invisible"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
