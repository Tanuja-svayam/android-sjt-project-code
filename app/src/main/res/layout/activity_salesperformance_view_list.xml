<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/list_selector"
    android:orientation="horizontal"
    android:padding="5dip" >

    <!--  ListRow Left sied Thumbnail image -->
    <LinearLayout android:id="@+id/thumbnail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="3dip"
        android:layout_alignParentLeft="true"
        android:background="@drawable/image_bg"
        android:layout_marginRight="5dip">

        <ImageView
            android:id="@+id/imageurl"
            android:layout_width="80dip"
            android:layout_height="80dip" />
    </LinearLayout>
    <!-- Title Of Song-->
    <TextView
        android:id="@+id/fullname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/thumbnail"
        android:layout_toRightOf="@+id/thumbnail"
        android:text=""
        android:textColor="#040404"
        android:typeface="sans"
        android:textSize="17dip"
        android:textStyle="bold"/>
    <!-- Artist Name -->

    <TextView
        android:id="@+id/sale_monthname_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/fullname"
        android:textColor="#343434"
        android:textSize="14dip"
        android:layout_marginTop="1dip"
        android:text="Last Month Sale : "
        android:layout_toRightOf="@+id/thumbnail"/>

    <!-- Artist Name -->
    <TextView
        android:id="@+id/sale_month_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/fullname"
        android:textColor="#343434"
        android:textSize="14dip"
        android:layout_marginTop="1dip"
        android:layout_marginRight="20dip"
        android:layout_alignParentRight="true"/>


    <!-- Artist Name -->
    <TextView
        android:id="@+id/sale_monthname_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/sale_monthname_1"
        android:textColor="#343434"
        android:textSize="14dip"
        android:layout_marginTop="1dip"
        android:text="Current Month : "
        android:layout_toRightOf="@+id/thumbnail"/>

    <TextView
        android:id="@+id/sale_month_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/sale_month_1"
        android:textColor="#343434"
        android:textSize="14dip"
        android:layout_marginTop="1dip"
        android:layout_marginRight="20dip"
        android:layout_alignParentRight="true"/>

    <TextView
        android:id="@+id/sale_monthname_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/sale_monthname_2"
        android:textColor="#343434"
        android:textSize="14dip"
        android:layout_marginTop="1dip"
        android:text="Current Month : "
        android:layout_toRightOf="@+id/thumbnail"/>

    <TextView
        android:id="@+id/sale_month_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/sale_month_2"
        android:textColor="#343434"
        android:textSize="14dip"
        android:layout_marginTop="1dip"
        android:layout_marginRight="20dip"
        android:layout_alignParentRight="true"/>

    <TextView
        android:id="@+id/ranklabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@+id/rank"
        android:layout_alignTop="@id/fullname"
        android:gravity="right"
        android:layout_marginRight="5dip"
        android:textSize="14dip"
        android:textColor="#006600"
        android:text="Rank"        />

    <!-- Rightend Duration -->
    <TextView
        android:id="@+id/rank"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:gravity="right"
        android:layout_marginRight="5dip"
        android:textSize="14dip"
        android:textColor="#006600"/>

</RelativeLayout>