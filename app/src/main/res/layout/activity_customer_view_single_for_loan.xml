<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dip" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/custname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <TextView
                android:id="@+id/overduelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Over Due : "/>
            <TextView
                android:id="@+id/overdue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <TextView
                android:id="@+id/duedatelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due Date : "/>
            <TextView
                android:id="@+id/duedate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <TextView
                android:id="@+id/contactpersonmobilelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile :"/>
            <TextView
                android:id="@+id/contactpersonmobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>


        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">
            <TextView
                android:id="@+id/telephonelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alternate Mobile :"/>
            <TextView
                android:id="@+id/telephone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>



        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/emaillabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emailidlabel"/>

            <TextView
                android:id="@+id/emailid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/cusaddresslabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address : " />

            <TextView
                android:id="@+id/cusaddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/referenceperson_namelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reference Name : " />

            <TextView
                android:id="@+id/referenceperson_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/referenceperson_mobilelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reference Contact : " />

            <TextView
                android:id="@+id/referenceperson_mobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/invoicenolabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Invoice No : " />

            <TextView
                android:id="@+id/invoiceno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/vinvoicedtlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Invoice Date : " />

            <TextView
                android:id="@+id/vinvoicedt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/vloandtlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loan Date : " />

            <TextView
                android:id="@+id/vloandt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/vfirstemidtlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First EMI : " />

            <TextView
                android:id="@+id/vfirstemidt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/vlastemidtlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last EMI : " />

            <TextView
                android:id="@+id/vlastemidt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/loanamtlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loan Amount : " />

            <TextView
                android:id="@+id/loanamt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/noofmonthlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tenor : " />

            <TextView
                android:id="@+id/noofmonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_width="fill_parent">

        <TextView
            android:id="@+id/emipermonthlabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMI : " />

        <TextView
            android:id="@+id/emipermonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_alignParentRight="true"
            android:layout_gravity="right"
            android:gravity="right"/>
    </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/processingfeelabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processing Fees : " />

            <TextView
                android:id="@+id/processingfee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/cardchargeslabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card Charges : " />

            <TextView
                android:id="@+id/cardcharges"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <TextView
                android:id="@+id/dbdamountlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DBD : " />

            <TextView
                android:id="@+id/dbdamount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_alignParentRight="true"
                android:layout_gravity="right"
                android:gravity="right"/>
        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/black"/>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ListView
                android:id="@+id/list_view"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:divider="#b5b5b5"
                android:dividerHeight="1dp"
                android:listSelector="@drawable/list_selector" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
