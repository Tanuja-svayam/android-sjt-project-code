<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/list_selector"
    android:orientation="horizontal"
    android:padding="5dip" >

    <!--  ListRow Left sied Thumbnail image -->
    <LinearLayout android:id="@+id/thumbnail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="3dip"
        android:layout_alignParentLeft="true"
        android:background="@drawable/image_bg"
        android:layout_marginRight="5dip">

        <ImageView
            android:id="@+id/modelimage"
            android:layout_width="50dip"
            android:layout_height="50dip" />
    </LinearLayout>
    <!-- Title Of Song-->
    <TextView
        android:id="@+id/modelcode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/thumbnail"
        android:layout_toRightOf="@+id/thumbnail"
        android:text="Rihanna Love the way lie"
        android:textColor="#040404"
        android:typeface="sans"
        android:textSize="17dip"
        android:textStyle="bold"/>
    <!-- Artist Name -->
    <TextView
        android:id="@+id/mrplabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/modelcode"
        android:textColor="#343434"
        android:textSize="17dip"
        android:layout_marginTop="1dip"
        android:text="@string/mrplabel"
        android:layout_toRightOf="@+id/thumbnail"/>

    <!-- Artist Name -->
    <TextView
        android:id="@+id/mrp"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/modelcode"
        android:textColor="#343434"
        android:textSize="17dip"
        android:layout_marginTop="1dip"
        android:layout_toRightOf="@+id/mrplabel"/>

    <!-- Artist Name -->
      <TextView
        android:id="@+id/dplabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/mrplabel"
        android:textColor="#343434"
        android:textSize="17dip"
        android:layout_marginTop="1dip"
        android:text="DP : "
        android:layout_toRightOf="@+id/thumbnail"/>

    <!-- Artist Name -->
    <TextView
        android:id="@+id/dp"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/mrplabel"
        android:textColor="#343434"
        android:textSize="17dip"
        android:layout_marginTop="1dip"
        android:layout_toRightOf="@+id/dplabel"/>

    <TextView
        android:id="@+id/slclabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/dplabel"
        android:textColor="#343434"
        android:textSize="17dip"
        android:layout_marginTop="1dip"
        android:text="SLC : "
        android:layout_toRightOf="@+id/thumbnail"/>

    <!-- Artist Name -->
    <TextView
        android:id="@+id/slc"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/dplabel"
        android:textColor="#343434"
        android:textSize="17dip"
        android:layout_marginTop="1dip"
        android:layout_toRightOf="@+id/slclabel"/>

    <!-- Rightend Duration -->
    <TextView
        android:id="@+id/stocklabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignTop="@id/modelcode"
        android:gravity="right"
        android:layout_marginRight="5dip"
        android:textSize="17dip"
        android:textColor="#006600"
        android:text=""        />

    <!-- Rightend Duration -->
    <TextView
        android:id="@+id/stock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_below="@id/stocklabel"
        android:gravity="right"
        android:layout_marginRight="5dip"
        android:textSize="17dip"
        android:textColor="#006600"/>


</RelativeLayout>