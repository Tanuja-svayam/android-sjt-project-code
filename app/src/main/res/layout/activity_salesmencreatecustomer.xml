        <!-- SECTION 1: Finance Details -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Rounded Header inside Card -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_header_bg"
                    android:text="Followup Details"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="10dp"
                    android:textSize="16sp"/>


                <!-- Content Area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/pickNextFollowupDatelbl"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint="NEXT FOLLOWUP DATE"
                        android:text="NEXT FOLLOWUP DATE : "
                        android:maxLines="1"/>

                    <TextView android:id="@+id/pickNextFollowupDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next Followup Date"
                        android:textStyle="bold"
                        android:textColor="#d40909"
                        android:textSize="18dp"
                        android:onClick="setPickNextFollowupDate"/>

                    <TextView
                        android:id="@+id/followuptime"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint="NEXT FOLLOWUP TIME"
                        android:text="NEXT FOLLOWUP TIME"
                        android:maxLines="1"/>

                    <EditText
                        android:id="@+id/NextFollowupTime"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint="Next Followup Time"
                        android:textStyle="bold"
                        android:textColor="#d40909"
                        android:textSize="18dp"
                        android:inputType="time"/>




                    <TextView
                        android:id="@+id/remarkslbl"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint="Note"
                        android:text="Note"
                        android:maxLines="1"/>

                    <EditText
                        android:id="@+id/remarks"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint=""
                        android:lines="4"
                        android:inputType="textMultiLine|textCapCharacters"
                        android:gravity="top|left"/>

                    <TextView
                        android:id="@+id/folupconversationlbl"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint="CONVERSATION"
                        android:text="CONVERSATION OR ACTIVITY CLOSED REASON"
                        android:maxLines="1"/>

                    <EditText
                        android:id="@+id/folupconversation"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:hint=""
                        android:lines="4"
                        android:inputType="textMultiLine|textCapCharacters"
                        android:gravity="top|left"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>






        <Button
            android:id="@+id/submit_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:onClick="onClick_submit"
            android:text="Submit"
            android:textColor="#fff"
            android:layout_margin="3dp"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:text="Create Quotation"
            android:textColor="@android:color/white"
            android:onClick="onClick_create_quotation"
            android:layout_margin="3dp"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:text="Create Order"
            android:textColor="@android:color/white"
            android:onClick="onClick_add_product"
            android:layout_margin="3dp"/>


        <TextView
            android:id="@+id/login_error"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="10dip"
            android:textColor="#e30000"
            android:textSize="15sp"
            android:textStyle="bold" />


    </LinearLayout>
</ScrollView>