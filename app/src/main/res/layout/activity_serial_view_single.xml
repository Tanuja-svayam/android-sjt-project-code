<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:label="@string/app_name">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/submit_addtoorder"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:onClick="onClick_serialno_add_to_Stock"
                android:text="Add To Stock"/>

        </LinearLayout>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dip"
            android:text="Serial No"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"/>

        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <EditText
                android:id="@+id/serialno"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_width="fill_parent">
            </EditText>



            <Button
                android:id="@+id/submit_serialno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="onClick_search_serialno"
                android:text="Search"/>
        </LinearLayout>

        <Button
            android:id="@+id/scan_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:layout_below="@id/scan_content"
            android:text="Scan"
            android:textColor="#fff" />

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dip"
            android:text="Sticker No"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"/>



        <LinearLayout
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_width="fill_parent">

            <EditText
                android:id="@+id/barcodeno"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_width="fill_parent">
            </EditText>

            <Button
                android:id="@+id/submit_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="onClick_update_sticker"
                android:text="Update"/>
        </LinearLayout>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Name" />

        <EditText
            android:id="@+id/stocklocation"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Brand" />

        <EditText
                android:id="@+id/brandname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Model" />

        <EditText
            android:id="@+id/modelname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Top Category"/>

        <EditText
            android:id="@+id/topcategoryname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Parent Categort" />

        <EditText
            android:id="@+id/parentcategoryname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Product Categort" />
        <EditText
            android:id="@+id/productcategorydesc"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>

         <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Age" />

        <EditText
            android:id="@+id/invetoryage"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Supplier"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/vendorname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Purchase Date" />

        <EditText
            android:id="@+id/vpurchasedt"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Supplier Ref. No" />

        <EditText
            android:id="@+id/refdocumentno"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:focusable="false"/>


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="MRP"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/mrp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Sale Price"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/vpp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:focusable="false"/>


        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="NLC"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/serial_netlancost"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:focusable="false"/>

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/statusdesc"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:focusable="false"/>

        <TextView
            android:id="@+id/login_error"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="10dip"
            android:textColor="#e30000"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>